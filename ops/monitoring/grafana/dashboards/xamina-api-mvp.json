{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Requests (rate)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {"expr": "sum(rate(axum_http_requests_total[5m])) by (method, status)", "legendFormat": "{{method}} {{status}}"}
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Latency p95",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(axum_http_request_duration_seconds_bucket[5m])) by (le, path))", "legendFormat": "{{path}}"}
      ]
    }
  ],
  "schemaVersion": 39,
  "title": "Xamina API MVP",
  "version": 1
}
