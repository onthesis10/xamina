DATABASE_URL=postgres://postgres:postgres@localhost:55432/xamina
REDIS_URL=redis://localhost:56379
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14
API_HOST=0.0.0.0
API_PORT=8080
GLOBAL_RATE_LIMIT_PER_MIN=120
AUTH_RATE_LIMIT_PER_MIN=20
IMPORT_RATE_LIMIT_PER_MIN=8
QUESTION_IMPORT_MAX_BYTES=2097152
QUESTION_IMPORT_MAX_ROWS=500
# AI provider selection:
# - Prefer OPENAI_* when OPENAI_API_KEY is set
# - Fallback to GROQ_* when OPENAI_API_KEY is empty and GROQ_API_KEY is set
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
AI_RATE_LIMIT_GENERATE_PER_MIN=12
AI_RATE_LIMIT_GRADE_PER_MIN=30
AI_RATE_LIMIT_EXTRACT_PER_MIN=10
AI_USAGE_RETENTION_DAYS=90
# Optional JSON map: {"gpt-4o-mini":{"prompt_per_1k_usd":0.00015,"completion_per_1k_usd":0.0006}}
AI_PRICING_JSON=
# Test-only: bypass provider and return deterministic response
AI_MOCK_MODE=0
# Certificate delivery (Sprint 10)
CERTIFICATE_PUBLIC_BASE_URL=http://localhost:8080/uploads/certificates
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@xamina.local
SMTP_FROM_NAME=Xamina
SMTP_STARTTLS=0
# VAPID private key must be raw base64url (URL_SAFE_NO_PAD), not PEM.
# Example generation (raw base64url private key):
# openssl ecparam -name prime256v1 -genkey -noout -out vapid_private.pem
# openssl ec -in vapid_private.pem -outform DER | tail -c 32 | base64 | tr '/+' '_-' | tr -d '='
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@xamina.local
# Billing (Sprint 13 batch 1)
BILLING_PROVIDER=mock
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_BASE_URL=https://app.sandbox.midtrans.com/snap/v1/transactions
MIDTRANS_MERCHANT_ID=
INVOICE_PUBLIC_BASE_URL=http://127.0.0.1:8080/uploads/invoices
BILLING_DUNNING_INTERVAL_SECS=30
BILLING_DUNNING_MAX_ATTEMPTS=3
# Optional override for uploads directory when running API from repo root
XAMINA_UPLOADS_DIR=
# Active storage mode for Sprint 3-4 closure: Local FS upload
UPLOAD_MODE=local
UPLOAD_BASE_URL=http://localhost:8080/uploads/question-images
UPLOAD_MAX_BYTES=5242880
# Reserved for next phase MinIO/S3-native transition (currently unused by upload endpoint)
S3_ENDPOINT=http://localhost:59000
S3_REGION=us-east-1
S3_BUCKET=xamina
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_BASE_URL=http://localhost:59000/xamina
