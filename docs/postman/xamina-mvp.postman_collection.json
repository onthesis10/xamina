          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Ujian Harian\",\n  \"description\": \"Sample exam\",\n  \"duration_minutes\": 60,\n  \"pass_score\": 70,\n  \"shuffle_questions\": false,\n  \"shuffle_options\": false,\n  \"start_at\": \"2026-03-01T09:00:00Z\",\n  \"end_at\": \"2026-03-01T10:00:00Z\"\n}"
        },
